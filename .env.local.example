# Copy this file to .env.local for local development.
# In production, set these as Vercel Environment Variables (Project Settings > Environment Variables).
# Never commit .env.local — it's already in .gitignore.

# Shared password required to use the app (simple single-password gate).
APP_PASSWORD=change-me

# Random secret used to sign the session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=

# OpenAI API key — used server-side only, never exposed to the browser. Powers outline/slide text.
OPENAI_API_KEY=

# OpenAI text model (kept as an env var so it can be swapped without a code change).
OPENAI_TEXT_MODEL=gpt-5

# Gemini API key (from https://aistudio.google.com/apikey) — used server-side only. Powers slide images.
GEMINI_API_KEY=

# Gemini image model ("Nano Banana"). Imagen models are being phased out for new API keys,
# so this defaults to Gemini's native image generation model instead.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Postgres connection string (Neon, provisioned via Vercel's Storage tab).
DATABASE_URL=

# Vercel Blob read/write token (created automatically when you add a Blob store on Vercel;
# for local dev, copy it from the Vercel dashboard).
BLOB_READ_WRITE_TOKEN=
